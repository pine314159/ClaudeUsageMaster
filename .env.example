# Fusion strategy configuration (optional overrides)
# Copy this file to .env and adjust values as needed.

# Log correction caps
CUM_LOG_CAP_LOW_CONF_THRESHOLD=0.3
CUM_LOG_CAP_MID_CONF_THRESHOLD=0.6
CUM_LOG_CAP_LOW=2.0
CUM_LOG_CAP_MID=4.0
CUM_LOG_CAP_HIGH=6.0

# Anti-self-inflation policy
CUM_CONFLICT_ENABLED=true
CUM_ASI_MILD_GAP_THRESHOLD=8.0
CUM_ASI_STRONG_GAP_THRESHOLD=15.0
CUM_ASI_MILD_PENALTY=-1.5
CUM_ASI_STRONG_PENALTY=-3.0
CUM_ASI_LOW_CONF_THRESHOLD=0.3
CUM_ASI_LOW_CONF_SCALE=0.5

# Hooks stability bonus
CUM_HOOKS_ENABLED=true
CUM_HOOKS_MIN_SAMPLE_SIZE=10
CUM_HOOKS_MIN_COVERAGE_DAYS=5
CUM_HOOKS_SESSION_NORM=60
CUM_HOOKS_DAY_NORM=30
CUM_HOOKS_SESSION_WEIGHT=0.4
CUM_HOOKS_DAY_WEIGHT=0.6
CUM_HOOKS_BONUS_CAP=1.5

